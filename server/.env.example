# ============================================================
# Bata, Takbo! — Server Environment Variables (Example Template)
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to version control.
# ============================================================

# Node environment: "development" or "production"
NODE_ENV=development

# Server port
PORT=3001

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_hex_jwt_secret_here

# AES-256 encryption key — MUST be exactly 64-character hex (32 bytes)
AES_SECRET_KEY=your_64_character_hex_aes_key_here

# Database URL (Used for PostgreSQL migration / Neon.tech)
DATABASE_URL=postgresql://username:password@hostname:port/database?sslmode=require

# Frontend URL (only used in production for CORS)
FRONTEND_URL=http://localhost:5173

# Email / SMTP (optional — email features disabled if not set)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ============================================================
# Admin Account Seeds
# These accounts are created automatically on server start
# if they don't already exist.
#
# To UPDATE an existing admin's email or password:
#   1. Edit the values below
#   2. Set ADMIN_SEED_FORCE=true
#   3. Restart the server
#   4. Set ADMIN_SEED_FORCE=false again (or remove the line)
# ============================================================


ADMIN_SEED_1_USERNAME=
ADMIN_SEED_1_EMAIL=
ADMIN_SEED_1_PASSWORD=

